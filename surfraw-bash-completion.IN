# -*- sh -*- bash programmable completion for Surfraw, v2.2

_surfraw ()
{
	local cur words=() cword
	_get_comp_words_by_ref -n = cur words cword

	local i=0
	local end_of_args=no
	# Determine end of args
	for word in "${words[@]}"
	do
		case "$word" in
			--) [[ $cword -ge $i ]] && end_of_args=yes ;;
		esac
		i="$(( i + 1 ))"
	done
	# Determine current elvis
	local elvis
	i=1
	# Skip "surfraw" or "sr" at start of command
	for word in "${words[@]:1}"
	do
		case "$word" in
			-*) : ignore options ;;
			*) elvis="$word"; break ;;
		esac
		i="$(( i + 1 ))"
	done

	local elvi="$(source surfraw
		cd "$(get_local_elvi_dir)" 2>/dev/null && echo *
		cd "$elvidir" 2>/dev/null && echo *
		cut -f1 "$(find_local_conf bookmarks)" "$(find_global_conf bookmarks)" 2>/dev/null)"

	if [[ $end_of_args = yes ]]
	then
		# Surfraw accepts the elvis name after the "--" argument
		if [[ -z "$elvis" ]]
		then
			COMPREPLY=( $(compgen -W "$elvi" -- "$cur") )
		else
			# We want to complete *something* for non-option, non-elvis arguments
			COMPREPLY=( $(compgen -o default -- "$cur") )
		fi
		return 0
	elif [[ -z "$elvis" ]]
	then
		case "$cur" in
			# Global options
			-*=*)
				# Match argument
				local arg="$(echo "$cur" | sed 's/[-_a-zA-Z0-9]*=//')"
				COMPREPLY=(
					$(compgen -W "$(surfraw -complete="$cur")" -- "$arg")
				)
				;;
			-*)
				# Appended spaces after completing options with arguments is annoying
				compopt -o nospace
				COMPREPLY=(
					$(compgen -W "$(surfraw -complete="$cur")" -- "$cur")
				)
				;;
			# Match elvi
			*) COMPREPLY=( $(compgen -W "$elvi" -- "$cur") ) ;;
		esac
		return 0
	fi

	# Is $elvis an existing elvis?
	if ! echo "$elvis" | grep "$(echo "$elvi" | sed 's/ /\\|/g')" >/dev/null
	then
		# $elvis == $cur
		COMPREPLY=( $(compgen -W "$elvi" -- "$cur") )
		return 0
	fi

	local completions="$(surfraw "$elvis" -complete="$cur")"
	case "$cur" in
		-*=*)
			# Match argument
			local arg="$(echo "$cur" | sed 's/[-_a-zA-Z0-9]*=//')"
			COMPREPLY=(
				$(compgen -W "$completions" -- "$arg")
			)
			;;
		-*)
			# Appended spaces after completing options with arguments is annoying
			compopt -o nospace
			COMPREPLY=( $(compgen -W "$completions" -- "$cur") )
			;;
		*)
			# We want to complete *something* for non-option, non-elvis arguments
			if [[ -z "$(echo "$completions" | tr -d '[:space:]')" ]]
			then
				COMPREPLY=( $(compgen -o default -- "$cur") )
			else
				COMPREPLY=( $(compgen -W "$completions" -- "$cur") )
			fi
			;;

	esac
	return 0
}
# test first in case removed-but-unpurged
type -p surfraw >/dev/null 2>&1 && complete -F _surfraw surfraw sr
